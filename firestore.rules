rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    function isArtist() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'artist';
    }

    // Users: readable by signed-in users, self-writable (can't self-assign admin)
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth.uid == userId && !('role' in request.resource.data && request.resource.data.role in ['admin']);
      allow update: if request.auth.uid == userId || isAdmin();
    }

    // Artworks: approved ones are public; artists manage their own; admins manage all
    match /artworks/{artworkId} {
      allow read: if resource.data.status == 'approved' || (request.auth != null && (isAdmin() || resource.data.artistId == request.auth.uid));
      allow create: if request.auth != null && isArtist();
      allow update: if request.auth != null && (isAdmin() || resource.data.artistId == request.auth.uid);
      allow delete: if request.auth != null && (isAdmin() || resource.data.artistId == request.auth.uid);
    }

    // Orders: customers see their own, artists see orders for their art, admins see all
    match /orders/{orderId} {
      allow read: if request.auth != null && (isAdmin() || resource.data.customerId == request.auth.uid || isArtist());
      allow create: if request.auth != null;
    }

    // Reviews: public read, authenticated create
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if request.auth != null;
    }

    // Verifications: artists see their own, admins manage all
    match /verifications/{verificationId} {
      allow read: if request.auth != null && (isAdmin() || resource.data.artistId == request.auth.uid);
      allow create: if request.auth != null && isArtist();
      allow update: if request.auth != null && isAdmin();
    }

    // Conversations
    match /conversations/{conversationId} {
      allow read: if request.auth != null && (isAdmin() || request.auth.uid in resource.data.participants);
      allow create: if request.auth != null && request.auth.uid in request.resource.data.participants;
      allow update: if request.auth != null && (isAdmin() || request.auth.uid in resource.data.participants);

      match /messages/{messageId} {
        allow read: if request.auth != null && (isAdmin() || request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants);
        allow create: if request.auth != null && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants;
      }
    }

    // Reports
    match /reports/{reportId} {
      allow read: if request.auth != null && isAdmin();
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && isAdmin();
    }
  }
}
